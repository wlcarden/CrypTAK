# FreeTAKServer + Headscale VPN environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Network ──────────────────────────────────────────────────────────────────
# Host machine LAN IP — the IP ATAK clients and browsers use to reach the server
UNRAID_IP=192.168.50.120

# ── Security ─────────────────────────────────────────────────────────────────
# Change ALL of these before first boot. Use random strings (pwgen 32 1, or similar).
FTS_FED_PASSWORD=changeme_federation_password
FTS_CLIENT_CERT_PASSWORD=changeme_cert_password
FTS_WEBSOCKET_KEY=changeme_websocket_key
FTS_SECRET_KEY=changeme_secret_key_32chars

# ── FTS API Key ───────────────────────────────────────────────────────────────
# Populated AFTER first FTS boot. See README "First Boot" section for instructions.
# Required for FTS-UI to authenticate against the REST API.
FTS_API_KEY=

# ── Headscale / VPN ───────────────────────────────────────────────────────────
# No secrets stored here — Headscale auth is managed via CLI after startup.
# See README "Headscale Setup" for enrollment steps.
#
# After Headscale is running, generate pre-auth keys with:
#   docker exec headscale headscale users create takteam
#   docker exec headscale headscale preauthkeys create --user takteam --reusable --expiration 90d
#
# Unraid host Tailscale enrollment (run on Unraid via SSH):
#   tailscale up --login-server https://tak.thousand-pikes.com \
#                --advertise-tags=tag:tak-server \
#                --authkey <key-from-above>
#
# Phone enrollment:
#   Tailscale app → ⋮ → "Use custom control server" → https://tak.thousand-pikes.com
#   Enter same pre-auth key (it's reusable)

# ── GitHub Actions Self-Hosted Runner (optional) ─────────────────────────
# Fine-grained PAT with Administration (read/write) on this repo.
# Enables automatic deployment on push to server/**.
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_RUNNER_TOKEN=

# ── Incident Tracker (optional) ────────────────────────────────────────────
# Only needed if incident tracker is enabled AND ai.enabled=true in config.yaml.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
