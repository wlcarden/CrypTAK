# CrypTAK Field Server — Environment Configuration
#
# Copy to .env.field and edit before first deploy:
#   cp .env.field.example .env.field
#   nano .env.field
#   docker compose -f docker-compose.field.yml --env-file .env.field up -d

# --- Network ---
# IP address of the Pi's AP interface (set by hostapd/dnsmasq)
FIELD_AP_IP=192.168.73.1

# --- FTS Security (change ALL of these) ---
FTS_SECRET_KEY=change-me-use-openssl-rand-hex-32
FTS_WEBSOCKET_KEY=change-me-use-openssl-rand-hex-32
FTS_FED_PASSWORD=change-me-federation-password
FTS_CLIENT_CERT_PASSWORD=change-me-cert-password

# --- Mumble ---
MUMBLE_PASSWORD=change-me-superuser-password

# --- HaLow Bridge ---
# Remote FTS host — Unraid's Tailscale IP. Leave empty to disable bridging.
REMOTE_FTS_HOST=100.64.0.1
REMOTE_FTS_PORT=8087

# Max events to buffer when VPN is down (each event ~1-2KB)
BUFFER_MAX=5000

# Bridge and FTS log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
