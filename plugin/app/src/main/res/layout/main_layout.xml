<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fadeScrollbars="false"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header with Logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/header_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/meshtasticLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/meshtastic_logo"
                android:scaleType="fitCenter"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Meshtastic Logo - Tap to visit website" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LoRa Mesh Network"
                    android:textSize="12sp"
                    android:textColor="#67EA94" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/settingsBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings_gear"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="Settings" />

        </LinearLayout>

        <!-- Role Warning Banner (shown when Role is not TAK) -->
        <LinearLayout
            android:id="@+id/roleWarningBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#B71C1C"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/roleWarningText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device Role is not set to TAK!\n\nFor optimal ATAK performance, your Meshtastic device Role must be set to TAK."
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <Button
                android:id="@+id/setRoleTakBtn"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:text="Set Role to TAK"
                android:textSize="13sp"
                android:textColor="#B71C1C"
                android:textStyle="bold"
                android:background="#FFFFFF" />

        </LinearLayout>

        <!-- Device Metrics Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Card Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Device Metrics"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/refreshMetricsBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Refresh"
                    android:textSize="11sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/accent_button_selector" />
            </LinearLayout>

            <!-- Node Name (Prominent) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/metric_item_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected Node"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/metricsNodeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textColor="#67EA94"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Metrics Grid Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Model -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginRight="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Model"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsModel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Firmware -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginLeft="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Firmware"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsFirmware"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Metrics Grid Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Battery -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginRight="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Voltage -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginLeft="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voltage"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsVoltage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Metrics Grid Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Ch Util -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginRight="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ch Util"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsChUtil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Air TX -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginLeft="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Air TX"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsAirTx"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Metrics Grid Row 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Uptime -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginRight="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uptime"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Nodes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginLeft="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Nodes"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsNodeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#67EA94"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Metrics Grid Row 5 - Config Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Region -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginRight="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Region"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsRegion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- LoRa Preset -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp"
                    android:layout_marginLeft="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LoRa Preset"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsLoraPreset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Metrics Grid Row 6 - Role -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Role -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/metric_item_bg"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textSize="10sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/metricsRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textColor="#67EA94"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Voice Controls Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Controls"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/talk"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="All Talk"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:background="@drawable/accent_button_selector"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/voiceMemoBtn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Speech to Text"
                    android:textSize="14sp"
                    android:textColor="#67EA94"
                    android:background="@drawable/secondary_button_selector"
                    android:layout_marginLeft="6dp" />

            </LinearLayout>

            <!-- Status Text -->
            <TextView
                android:id="@+id/tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
