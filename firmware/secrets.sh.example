# CrypTAK Firmware Secrets
# Copy to secrets.sh and fill in your values. Never commit secrets.sh.
#
# Generate a new admin key pair:
#   meshtastic --gen-config
#   or: python3 -c "
#     from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#     import base64
#     k = Ed25519PrivateKey.generate()
#     priv = base64.b64encode(k.private_bytes_raw()).decode()
#     pub  = base64.b64encode(k.public_key().public_bytes_raw()).decode()
#     print(f'Private: base64:{priv}')
#     print(f'Public:  base64:{pub}')
#   "
#
# Set security.admin_key on each node to your PUBLIC key.
# Keep the private key here for use with --admin-key flag when sending remote admin packets.

ADMIN_KEY="base64:REPLACE_WITH_YOUR_PUBLIC_KEY"

# Admin channel PSK — shared secret for channel 1 ("admin") on all nodes.
# Enables remote admin over LoRa and friendly-node identification.
# Generate: meshtastic --ch-set psk random --ch-index 1
# Then read back: meshtastic --info | grep "Index 1"
ADMIN_CHANNEL_PSK="base64:REPLACE_WITH_YOUR_ADMIN_CHANNEL_PSK"
