# CrypTAK Firmware Secrets
# Copy to secrets.sh and fill in your values. Never commit secrets.sh.
#
# ADMIN_KEY — BRG01 (workbench admin device) public key.
# Authority to remotely admin field nodes via PKC is held by BRG01.
# BRG01 must be provisioned first. Get its public key with:
#   meshtastic --host <brg01-ip> --info | grep '"publicKey"' | head -1
# Then paste it here (no "base64:" prefix — it's already base64).
# Rotation: factory-reset BRG01 (or use a new device), get new public key,
# update this file, and reprovision all field nodes.
ADMIN_KEY="REPLACE_WITH_BRG01_PUBLIC_KEY"

# Admin channel PSK — shared secret for channel 1 ("cryptak") on all nodes.
# Belt-and-suspenders alongside PKC. Any node on this channel can relay admin.
# Also used for fleet IFF (friendly-node identification).
# Generate a new PSK: meshtastic --ch-set psk random --ch-index 1
# Then read back: meshtastic --info | grep "Index 1"
ADMIN_CHANNEL_PSK="base64:REPLACE_WITH_YOUR_ADMIN_CHANNEL_PSK"
